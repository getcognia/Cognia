# =============================================================================
# Cognia API Environment Variables
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Application Configuration
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000


# Disable colors in logs (set to 1 to disable)
NO_COLOR=0

# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# PostgreSQL connection string
# Format: postgresql://[user]:[password]@[host]:[port]/[database]
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cognia

# -----------------------------------------------------------------------------
# Redis Configuration
# -----------------------------------------------------------------------------
# Option 1: Use Redis URL (recommended for cloud Redis)
REDIS_URL=redis://localhost:6379

# Option 2: Use individual connection parameters
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=

# Redis command timeout in milliseconds (default: 60000 = 60 seconds)
REDIS_COMMAND_TIMEOUT_MS=60000

# -----------------------------------------------------------------------------
# Qdrant Vector Database Configuration
# -----------------------------------------------------------------------------
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
EMBEDDING_DIMENSION=1536

# -----------------------------------------------------------------------------
# AI Provider Configuration
# -----------------------------------------------------------------------------
# Provider options: 'openai', 'gemini', 'ollama', or 'hybrid' (default: 'openai')
# Keep EMBEDDING_DIMENSION aligned with the embedding model in use.
AI_PROVIDER=openai
EMBED_PROVIDER=openai
GEN_PROVIDER=openai

# OpenAI API Configuration (default for generation, embeddings, and vision)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_EMBED_MODEL=gemini-embedding-001

# Ollama Configuration (for local AI models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL="nomic-embed-text"
OLLAMA_GEN_MODEL="llama3.1:8b"

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m

# Refresh token lifetime in days (opaque tokens persisted in DB, rotated on use)
REFRESH_TOKEN_EXPIRES_IN_DAYS=14

# -----------------------------------------------------------------------------
# CORS & Security Configuration
# -----------------------------------------------------------------------------
# Cookie domain (default: '.cognia.xyz')
COOKIE_DOMAIN=.cognia.xyz

# Session cookie name (default: 'cognia_session')
SESSION_COOKIE_NAME=cognia_session

# Cookie secure flag (default: true)
# Set to 'false' for development over HTTP
COOKIE_SECURE=true

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=

# Chrome extension IDs (comma-separated)
# Example: abcdefghijklmnopqrstuvwxyz123456,chrome-extension://abcdefghijklmnopqrstuvwxyz123456
EXTENSION_IDS=

# -----------------------------------------------------------------------------
# Request Timeouts (in milliseconds)
# -----------------------------------------------------------------------------
# General request timeout (default: 60000 = 60 seconds)
REQUEST_TIMEOUT_MS=60000

# Search request timeout (default: 360000 = 6 minutes)
SEARCH_TIMEOUT_MS=360000

# Insights generation timeout (default: 360000 = 6 minutes)
INSIGHTS_TIMEOUT_MS=360000

# Email draft generation timeout (default: 360000 = 6 minutes)
EMAIL_DRAFT_TIMEOUT_MS=360000

# -----------------------------------------------------------------------------
# Queue Configuration (BullMQ)
# -----------------------------------------------------------------------------
# Queue rate limiter: max jobs per duration.
# For OpenAI-backed processing, keep this conservative because a single job can
# fan out into multiple API calls (embeddings + profile generation).
QUEUE_RATE_MAX=1
QUEUE_RATE_DURATION_MS=60000

# Queue concurrency (number of jobs processed simultaneously)
QUEUE_CONCURRENCY=1

# Queue stalled interval in milliseconds (default: 300000 = 5 minutes)
QUEUE_STALLED_INTERVAL_MS=300000

# Maximum number of times a job can be stalled before failing (default: 10)
QUEUE_MAX_STALLED_COUNT=10

# -----------------------------------------------------------------------------
# Search Configuration
# -----------------------------------------------------------------------------
# Default number of results to return (default: 50)
SEARCH_TOP_K=50

# Maximum number of results allowed (default: 1000)
SEARCH_MAX_LIMIT=1000

# Enable reasoning in search (default: true, set to 'false' to disable)
SEARCH_ENABLE_REASONING=true

# Salt for search embedding hashing (default: 'cognia')
SEARCH_EMBED_SALT=cognia

# -----------------------------------------------------------------------------
# Hybrid Retrieval & Reranking
# -----------------------------------------------------------------------------
# Cross-encoder reranker provider order. Set RERANK_PROVIDER to one of
# 'cohere' | 'voyage' | 'jina' | 'passthrough' to force a specific provider,
# or leave blank to auto-pick the first one with an API key set. The
# 'passthrough' option disables reranking and returns hybrid-fused results
# in their original order -- useful for local dev without paid API access.
RERANK_PROVIDER=

# Cohere rerank API (recommended primary; rerank-v3.5 is the default model).
COHERE_API_KEY=
COHERE_RERANK_MODEL=rerank-v3.5

# Voyage rerank API (high-quality alternative).
VOYAGE_API_KEY=
VOYAGE_RERANK_MODEL=rerank-2

# Jina rerank API (multilingual reranker).
JINA_API_KEY=
JINA_RERANK_MODEL=jina-reranker-v2-base-multilingual

# Hard timeout for any single rerank call (default: 15000ms).
RERANK_TIMEOUT_MS=15000

# -----------------------------------------------------------------------------
# Mesh Recompute (background job)
# -----------------------------------------------------------------------------
# Cron pattern for the nightly mesh recompute (UTC). Default 03:00 UTC.
MESH_RECOMPUTE_CRON=0 3 * * *

# How long the mesh snapshot is considered fresh enough to serve directly
# from cache. Older snapshots fall through to a live recompute.
MESH_SNAPSHOT_MAX_AGE_MS=86400000

# -----------------------------------------------------------------------------
# Ingest Backfill
# -----------------------------------------------------------------------------
# Number of memories per batch in the backfill-search-index script.
BACKFILL_BATCH_SIZE=64

# -----------------------------------------------------------------------------
# Memory Configuration
# -----------------------------------------------------------------------------
# Memory decay half-life in days (default: 21)
MEMORY_DECAY_HALF_LIFE_DAYS=21

# Profile importance threshold (default: 0.7)
# Memories with importance score above this threshold are included in profile
PROFILE_IMPORTANCE_THRESHOLD=0.7

# -----------------------------------------------------------------------------
# Profile Worker Configuration
# -----------------------------------------------------------------------------
# Days since last update to trigger profile update (default: 7)
PROFILE_UPDATE_INTERVAL_DAYS=7

# Hours between profile update cycles (default: 24)
PROFILE_UPDATE_CYCLE_HOURS=24

# Reserve OpenAI text generation for search requests only.
# When enabled, non-search OpenAI generation is blocked and the profile/briefing workers do not start.
OPENAI_SEARCH_ONLY_MODE=false

# Hours to wait before retrying profile update for users with no memories (default: 6)
PROFILE_NO_MEMORIES_COOLDOWN_HOURS=6

# -----------------------------------------------------------------------------
# Insights Worker Configuration
# -----------------------------------------------------------------------------
# Hours between daily insights generation (default: 24)
INSIGHTS_DAILY_INTERVAL_HOURS=24

# Hours between weekly insights generation (default: 168 = 7 days)
INSIGHTS_WEEKLY_INTERVAL_HOURS=168

# -----------------------------------------------------------------------------
# Logging Configuration
# -----------------------------------------------------------------------------
# Logger output mode: 'print', 'log', 'both', or 'none' (default: 'log')
LOGGER_OUTPUT_MODE=log

# Morgan (HTTP logging) output mode: 'print', 'log', 'both', or 'none' (default: 'print')
MORGAN_OUTPUT_MODE=print

# Log file path (default: './logs/app.log')
LOG_FILE_PATH=./logs/app.log

# -----------------------------------------------------------------------------
# Performance Profile
# -----------------------------------------------------------------------------
# Performance profile: 'minimal', 'standard', or 'full' (default: 'full')
COGNIA_PROFILE=full

# -----------------------------------------------------------------------------
# Document Intelligence (Second Brain) Configuration
# -----------------------------------------------------------------------------
# Storage provider: 'local', 's3', or 'r2' (default: 'local')
STORAGE_PROVIDER=local

# Local storage directory (for local provider)
LOCAL_STORAGE_PATH=./uploads

# AWS S3 Configuration
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=
S3_PUBLIC_URL_BASE=

# Cloudflare R2 Configuration
R2_BUCKET=
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_PUBLIC_URL_BASE=

# -----------------------------------------------------------------------------
# External Integrations Configuration
# -----------------------------------------------------------------------------
# REQUIRED. 32-byte hex key (64 chars). Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=

# 32-byte hex key (64 chars). Generate with: openssl rand -hex 32
TWO_FACTOR_ENCRYPTION_KEY=

# API base URL (used for OAuth callbacks)
API_BASE_URL=http://localhost:3000

# Frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# Google Drive Integration
GOOGLE_DRIVE_CLIENT_ID=
GOOGLE_DRIVE_CLIENT_SECRET=
GOOGLE_DRIVE_REDIRECT_URI=http://localhost:3000/api/integrations/google_drive/callback

# Slack Integration
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/integrations/slack/callback

# Notion Integration
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:3000/api/integrations/notion/callback

# Box Integration
BOX_CLIENT_ID=
BOX_CLIENT_SECRET=
BOX_REDIRECT_URI=http://localhost:3000/api/integrations/box/callback
BOX_PRIMARY_WEBHOOK_KEY=
BOX_SECONDARY_WEBHOOK_KEY=

# GitHub Integration (coming soon)
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_WEBHOOK_SECRET=

# Emergency-only. When 'true', security middleware fails OPEN on internal errors
# instead of returning 503. Use only during an active incident, then unset.
SECURITY_FAIL_OPEN_BREAKGLASS=

# -----------------------------------------------------------------------------
# OAuth Sign-In Providers
# -----------------------------------------------------------------------------
# OAuth providers (optional; needed for "Sign in with Google/Microsoft")
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# Public URLs for OAuth redirect construction
PUBLIC_API_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:5173

# Razorpay Billing (optional; billing endpoints return 503 when unset)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_PRO=
RAZORPAY_PLAN_ENTERPRISE=

